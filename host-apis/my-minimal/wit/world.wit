package gams:js@1.0.0;

/// JavaScript runner plugin for the GAMS component-model runtime.
///
/// This intentionally mirrors `gams:lua/lua@1.0.0` at the public boundary:
/// the runner is a singleton component exporting `run(source)` and importing
/// `gams:runtime/runtime@1.0.0` for future host/plugin/view calls.
interface js {
  run: func(source: string) -> result<string, string>;
}

world js-plugin {
  import gams:runtime/runtime@1.0.0;

  export js;
}
